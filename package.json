{
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build && vite build --ssr",
        "dev": "vite",
        "tsc": "vue-tsc --build --force",
        "format": "FILES=\"$(git diff --name-only --diff-filter=d HEAD -- '*.ts' '*.tsx' '*.vue'; git ls-files --others --exclude-standard -- '*.ts' '*.tsx' '*.vue')\"; [ -z \"$FILES\" ] || prettier -w $FILES",
        "format-all": "prettier -w resources/js/",
        "format:watch": "npx onchange \"**/*.{js,ts,tsx,vue}\" -- npm run format"
    },
    "devDependencies": {
        "@inertiajs/vue3": "^1.0.14",
        "@tailwindcss/forms": "^0.5.7",
        "@tailwindcss/typography": "^0.5.10",
        "@vitejs/plugin-vue": "^5.0.0",
        "@vue/server-renderer": "^3.3.13",
        "@vue/tsconfig": "^0.7.0",
        "autoprefixer": "^10.4.16",
        "axios": "^1.7.4",
        "concurrently": "^9.0.1",
        "eslint": "^9.36.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.4",
        "laravel-vite-plugin": "^1.0",
        "postcss": "^8.4.32",
        "prettier": "^3.6.2",
        "tailwindcss": "^3.4.0",
        "typescript": "^5.7.3",
        "vite": "^5.0",
        "vue": "^3.3.13"
    },
    "dependencies": {
        "@primevue/themes": "^4.2.5",
        "date-fns": "^4.1.0",
        "html2canvas": "^1.4.1",
        "primeicons": "github:primefaces/primeicons",
        "primevue": "^4.5.4",
        "sass": "^1.83.1",
        "tailwindcss-primeui": "^0.4.0",
        "vue-tsc": "^2.2.0",
        "vue-uuid": "^3.0.0",
        "ziggy-js": "github:tightenco/ziggy"
    }
}
